{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "tspack/manifest": [".tspack/types/tspack-manifest.d.ts"]
    }
  },
  "include": [
    "manifest.tsx",
    "package.manifest.tsx",
    "**/*.manifest.tsx",
    "**/*.xtest.tsx",
    ".tspack/types/**/*.d.ts"
  ],
  "exclude": [
    "src/**",
    "dist/**",
    "node_modules/**",
    ".tspack/store/**",
    "tspack-artifacts/**"
  ]
}
